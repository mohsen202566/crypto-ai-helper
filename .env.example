# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Toobit Spot API
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_API_KEY=
TOOBIT_API_SECRET=
RECV_WINDOW=5000

# Toobit Spot endpoints - اگر API توبیت مسیر دیگری داشت، فقط همین‌ها را تغییر بده
TOOBIT_SPOT_PATH_EXCHANGE_INFO=/api/v1/spot/exchangeInfo
TOOBIT_SPOT_PATH_BALANCE=/api/v1/spot/account
TOOBIT_SPOT_PATH_ORDER=/api/v1/spot/order
TOOBIT_SPOT_PATH_OPEN_ORDERS=/api/v1/spot/openOrders
TOOBIT_SPOT_PATH_ORDER_HISTORY=/api/v1/spot/historyOrders
TOOBIT_SPOT_PATH_ORDER_HISTORY_ALT=/api/v1/spot/order/history

# OKX public market data
OKX_BASE_URL=https://www.okx.com

# Data
BOT_DATA_DIR=./data
BOT_LOCK_FILE=/tmp/crypto-ai-helper-spot-hunter.lock

# Timing
REQUEST_TIMEOUT=15
SCAN_INTERVAL_SECONDS=60
NORMAL_MONITOR_INTERVAL_SECONDS=60
BUY_CONFIRM_DELAY_SECONDS=5
BUY_FILL_TIMEOUT_SECONDS=70
BUY_FILL_POLL_SECONDS=5

# Strategy
MIN_SIGNAL_SCORE=85
WARN_SIGNAL_SCORE=75
MAX_LAST_HOUR_PUMP_PCT=4.0
MIN_PULLBACK_PCT=0.4
MAX_PULLBACK_PCT=8.0
MIN_VOLUME_RATIO=0.75

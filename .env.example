# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OWNER_ID=

# Toobit
TOOBIT_API_KEY=
TOOBIT_SECRET_KEY=
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_RECV_WINDOW=5000
TOOBIT_TIMEOUT_SECONDS=12
TOOBIT_VERIFY_AFTER_ERROR_SECONDS=70
TOOBIT_MARGIN_TOLERANCE_PCT=1.0

# Bot runtime
BOT_DATA_DIR=data
BOT_DB_PATH=data/bot.sqlite3
BOT_NAME=AI Helper Hunter Bot v2

# Scan intervals
SCAN_INTERVAL_SECONDS=60
WATCH_SCAN_INTERVAL_SECONDS=15
MONITOR_INTERVAL_SECONDS=10
TOOBIT_PANEL_CACHE_SECONDS=30

# Watchlist
MAX_WATCH_SYMBOLS=5
WATCH_EXPIRE_SECONDS=600
READY_ALERT_COOLDOWN_SECONDS=180

# Signal
SIGNAL_THRESHOLD=75
DEFAULT_TRADE_ENABLED=false

# Trade settings
DEFAULT_MARGIN_USDT=10
DEFAULT_LEVERAGE=5
DEFAULT_MAX_POSITIONS=3
DEFAULT_MIN_PROFIT_USDT=1
DEFAULT_MIN_PROFIT_PCT=0.20

# Cost / Net Edge
TOOBIT_TAKER_FEE=0.0006
TOOBIT_MAKER_FEE=0.0002
SPREAD_BUFFER=0.0004
SLIPPAGE_BUFFER=0.0005
MIN_NET_EDGE=0.0015
MIN_RISK_REWARD=1.15

# Learning
AI_MEMORY_DAYS=20
AI_MIN_EFFECT_SAMPLES=20
AI_VALID_EXPERIENCE_SAMPLES=100

# Symbol health
SYMBOL_ERROR_LIMIT=3
OKX_DISABLE_SECONDS=1800
TOOBIT_REAL_DISABLE_SECONDS=21600

# Toobit endpoint overrides if your account/API variant needs them
# TOOBIT_PATH_BALANCE=/api/v1/futures/balance
# TOOBIT_PATH_POSITIONS=/api/v1/futures/positions
# TOOBIT_PATH_OPEN_ORDERS=/api/v1/futures/openOrders
# TOOBIT_PATH_MARGIN_MODE=/api/v1/futures/marginType
# TOOBIT_PATH_LEVERAGE=/api/v1/futures/leverage
# TOOBIT_PATH_POSITION_SETTINGS=/api/v1/futures/accountLeverage
# TOOBIT_PATH_ORDER=/api/v1/futures/order
# TOOBIT_PATH_MARK_PRICE=/api/v1/futures/markPrice
# TOOBIT_PATH_EXCHANGE_INFO=/api/v1/futures/exchangeInfo
# TOOBIT_PARAM_TP=takeProfit
# TOOBIT_PARAM_SL=stopLoss

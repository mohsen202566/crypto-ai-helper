# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Toobit real execution
TOOBIT_API_KEY=
TOOBIT_API_SECRET=
# سازگاری با نسخه‌های قبلی؛ یکی از این دو کافی است
TOOBIT_SECRET_KEY=
TOOBIT_BASE_URL=https://api.toobit.com
RECV_WINDOW=5000
REQUEST_TIMEOUT=12

# OKX analysis only
OKX_BASE_URL=https://www.okx.com

# Runtime defaults
DEFAULT_TRADE_ENABLED=false
DEFAULT_TRADE_AMOUNT_USDT=10
DEFAULT_LEVERAGE=10
DEFAULT_MAX_POSITIONS=1
DEFAULT_MARGIN_TYPE=ISOLATED
POLL_INTERVAL_SECONDS=4
SYMBOL_ERROR_COOLDOWN_SECONDS=60

# v15 MTF trend filter
MARKET_TREND_REFRESH_SECONDS=300
MARKET_TREND_MIN_AGREEMENT=0.55
MARKET_TREND_MIN_SYMBOLS=8
MARKET_TREND_CANDLE_LIMIT=160
ENTRY_CONFIRM_TIMEFRAME=15m
ENTRY_CONFIRM_CANDLE_LIMIT=120
REQUIRE_CUSTOM_PROFILE_FOR_SIGNAL=true

# v15 TP/SL for 2-3 hour target
SIGNAL_MAX_HOLD_MINUTES=180

# v15 support/resistance filter
SR_FILTER_ENABLED=true
SR_CANDLE_LIMIT_1H=180
SR_CANDLE_LIMIT_4H=120
SR_MIN_REACTION_PERCENT=0.60
SR_ZONE_WIDTH_PERCENT=0.30
SR_MIN_TOUCHES=2
SR_MIN_STRENGTH=4.50

# v15 daily rolling indicator-range optimizer, still on 5m entry candles
ROLLING_OPTIMIZER_ENABLED=true
ROLLING_OPTIMIZER_RUN_HOUR=0
ROLLING_OPTIMIZER_RUN_MINUTE=10
ROLLING_OPTIMIZER_DAYS=30
ROLLING_OPTIMIZER_TARGET_MOVE_PERCENT=1.30
ROLLING_OPTIMIZER_ADVERSE_PERCENT=0.60
ROLLING_OPTIMIZER_MAX_HOLD_CANDLES=36
ROLLING_OPTIMIZER_MIN_GOOD_MOVES=20

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# OKX analysis data only
# تحلیل فقط از OKX گرفته می‌شود
# =========================
OKX_BASE_URL=https://www.okx.com

# =========================
# Toobit real execution
# اجرای معامله فقط روی Toobit انجام می‌شود
# کلیدهای واقعی را فقط داخل فایل .env بگذار، نه داخل گیت‌هاب
# =========================
TOOBIT_API_KEY=
TOOBIT_API_SECRET=
TOOBIT_BASE_URL=https://api.toobit.com
RECV_WINDOW=5000
REQUEST_TIMEOUT=12

# =========================
# Bot runtime
# =========================
POLL_INTERVAL_SECONDS=4
SYMBOL_ERROR_COOLDOWN_SECONDS=60

# =========================
# Trade defaults
# قابل تغییر با دستورات فارسی داخل تلگرام
# /دلار_ترید 1..10000
# /لوریج_ترید 1..100
# /حداکثر_پوزیشن 1..100
# =========================
DEFAULT_TRADE_ENABLED=false
DEFAULT_TRADE_AMOUNT_USDT=10
DEFAULT_LEVERAGE=10
DEFAULT_MAX_POSITIONS=1
DEFAULT_MARGIN_TYPE=ISOLATED

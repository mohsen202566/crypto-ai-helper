# =========================
# Persian Crypto Trading Assistant Bot - Futures Only
# Copy this file to .env and fill your real values.
# Do NOT commit .env to GitHub.
# =========================

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=0
OWNER_ID=0
BOT_NAME=AI Range Learning 5m Futures Bot

# Runtime / database
DATA_DIR=data
DB_PATH=data/bot.db
BOT_TIMEZONE=Asia/Baku

# OKX market data
OKX_BASE_URL=https://www.okx.com
OKX_CANDLE_LIMIT=300
OKX_TIMEOUT_SECONDS=12
MIN_ENTRY_CANDLES=205
MIN_HTF_CANDLES=60

# Toobit Futures API
TOOBIT_API_KEY=
TOOBIT_SECRET_KEY=
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_RECV_WINDOW=5000
TOOBIT_TIMEOUT_SECONDS=12
TOOBIT_VERIFY_AFTER_ERROR_SECONDS=70
TOOBIT_MARGIN_TOLERANCE_PCT=1.0

# Optional Toobit endpoint overrides. Keep defaults unless Toobit API paths change.
TOOBIT_PATH_BALANCE=/api/v1/futures/balance
TOOBIT_PATH_POSITIONS=/api/v1/futures/positions
TOOBIT_PATH_OPEN_ORDERS=/api/v1/futures/openOrders
TOOBIT_PATH_MARGIN_MODE=/api/v1/futures/marginType
TOOBIT_PATH_LEVERAGE=/api/v1/futures/leverage
TOOBIT_PATH_POSITION_SETTINGS=/api/v1/futures/accountLeverage
TOOBIT_PATH_ORDER=/api/v1/futures/order
TOOBIT_PATH_MARK_PRICE=/api/v1/futures/markPrice
TOOBIT_PATH_EXCHANGE_INFO=/api/v1/futures/exchangeInfo
TOOBIT_PATH_HISTORY_POSITIONS=/api/v1/futures/historyPositions
TOOBIT_PATH_TODAY_PNL=/api/v1/futures/todayPnl
TOOBIT_PARAM_TP=takeProfit
TOOBIT_PARAM_SL=stopLoss

# Scanner / monitor
SCANNER_SECONDS=45
MONITOR_SECONDS=10
RUN_REPLAY_ON_START=0
REPLAY_DAYS=7
REPLAY_MAX_CANDLES=2200

# Default trading settings. Real trading starts disabled unless you turn it on from Telegram.
DEFAULT_TRADE_ENABLED=0
DEFAULT_MARGIN_USDT=5
DEFAULT_LEVERAGE=10
DEFAULT_MAX_POSITIONS=3
REAL_OPEN_VERIFY_SECONDS=70
PANEL_CACHE_SECONDS=20

# Futures-only fee accounting. Toobit LV.1 Futures taker = 0.0500% = 0.0005.
TAKER_FEE_RATE=0.0005
FUTURES_MAKER_FEE_RATE=0.0002
FUTURES_TAKER_FEE_RATE=0.0005
FEE_SIDE_MODE=taker
SLIPPAGE_BUFFER_RATE=0.0002
MIN_NET_PROFIT_USDT=0.01
MIN_RISK_REWARD=1.20
SAFE_TP_FRACTION_MIN=0.65
SAFE_TP_FRACTION_MAX=0.82

# Learning / signal quality
INITIAL_SOFT_MODE=1
BOOT_NORMAL_SAMPLE_LIMIT=50
REAL_MIN_SAMPLES=30
STRONG_CONFIDENCE_SAMPLES=150
MIN_ATR_PCT=0.0008
MAX_ATR_PCT=0.018
MIN_ADX_SOFT=14
MIN_ADX_HARD_BLOCK=10
MAX_VOLUME_RATIO_SOFT=3.8
MAX_VOLUME_RATIO_HARD=5.5
MIN_VOLUME_RATIO_SOFT=0.70
MIN_VOLUME_RATIO_HARD=0.45
PRICE_TICK_DECIMALS=8

# Session guard
SESSION_GUARD_ENABLED=1
SESSION_CAUTION_MIN_CONFIDENCE=35
# Format: HH:MM-HH:MM|LEVEL|LABEL|reason ; LEVEL = CAUTION, REAL_BLOCK, BLOCK
SESSION_WINDOWS=10:00-10:30|CAUTION|EUROPE_TRANSITION|شروع/تغییر جریان اروپا؛ احتمال فیک‌موو و برگشت جهت بیشتر است;11:00-11:30|REAL_BLOCK|EUROPE_VOLATILITY|نوسان اروپا می‌تواند جهت آلت‌ها را سریع عوض کند;17:25-18:05|REAL_BLOCK|US_DATA_WINDOW|اطراف انتشار داده‌های آمریکا Real بسته و Normal سخت‌گیر شود;18:25-19:10|CAUTION|US_OPEN|شروع بازار آمریکا معمولاً نویز و اسپایک بیشتری دارد

# Stop / drawdown guard
RISK_GUARD_ENABLED=1
STOP_GUARD_LOOKBACK_MINUTES=60
STOP_GUARD_MIN_STREAK=3
STOP_GUARD_MIN_COUNT=3
STOP_GUARD_COOLDOWN_MINUTES=5
STOP_GUARD_EXTENDED_COOLDOWN_MINUTES=15
STOP_PROFILE_MIN_SAMPLES=4
STOP_PROFILE_BAD_SL_RATE=65
STOP_PROFILE_HARD_SL_RATE=80

# Fundamental guard: only market-wide macro/crypto shock news affects trading.
FUNDAMENTAL_GUARD_ENABLED=1
FUNDAMENTAL_ALERT_BEFORE_MINUTES=5
FUNDAMENTAL_BLOCK_BEFORE_MINUTES=5
FUNDAMENTAL_BLOCK_AFTER_MINUTES=20
FUNDAMENTAL_STRICT_AFTER_MINUTES=45
FUNDAMENTAL_REFRESH_MINUTES=10
FUNDAMENTAL_FEED_TIMEOUT_SECONDS=8
FUNDAMENTAL_LOCAL_EVENTS_PATH=fundamental_events.json
# Optional comma-separated RSS/Atom feed URLs. Leave empty if you only use fundamental_events.json.
FUNDAMENTAL_FEED_URLS=
# Optional inline JSON array/object for scheduled market-wide events.
FUNDAMENTAL_EVENTS_JSON=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OWNER_ID=

# Toobit real execution
TOOBIT_API_KEY=
TOOBIT_SECRET_KEY=
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_RECV_WINDOW=5000
TOOBIT_TIMEOUT_SECONDS=12
TOOBIT_VERIFY_AFTER_ERROR_SECONDS=70
TOOBIT_MARGIN_TOLERANCE_PCT=1.0

# OKX analysis data only
OKX_BASE_URL=https://www.okx.com
OKX_CANDLE_LIMIT=260

# Bot runtime
BOT_DATA_DIR=data
BOT_DB_PATH=data/crypto_ai_helper_1h.sqlite3
BOT_NAME=Crypto AI Helper 1H Soft AI
TZ=UTC
LOG_LEVEL=INFO

# 1H scan cadence
# Main analysis: 1H | Context: 4H | Entry timing: 30m/15m
FULL_SCAN_SECONDS=300
WATCH_SCAN_SECONDS=30
MONITOR_INTERVAL_SECONDS=10
TOOBIT_PANEL_CACHE_SECONDS=20
MAX_WATCH_SYMBOLS=8
WATCH_EXPIRE_SECONDS=7200
READY_ALERT_COOLDOWN_SECONDS=1800

# Soft AI starting points only
# These are NOT fixed rules. AI adjusts per symbol/direction/pattern/score bucket.
BASE_SIGNAL_THRESHOLD=68
BASE_REAL_THRESHOLD=76
WATCH_THRESHOLD=42
GHOST_THRESHOLD=56
MIN_DYNAMIC_SIGNAL_THRESHOLD=50
MAX_DYNAMIC_SIGNAL_THRESHOLD=90
MIN_DYNAMIC_REAL_THRESHOLD=58
MAX_DYNAMIC_REAL_THRESHOLD=94

# Trade panel defaults - user controlled only
# AI may suggest changes, but must not change these by itself.
DEFAULT_TRADE_ENABLED=false
DEFAULT_MARGIN_USDT=10
DEFAULT_LEVERAGE=5
DEFAULT_MAX_POSITIONS=3

# Real execution safety / cost model
MIN_REAL_NET_PROFIT_USDT=0.01
ESTIMATED_FIXED_ROUND_FEE_USDT=0.0
TOOBIT_TAKER_FEE=0.0006
SPREAD_BUFFER=0.00025
SLIPPAGE_BUFFER=0.00035
MIN_OKX_TOOBIT_SYNC_PCT=0.0025
MIN_RISK_REWARD=1.20

# 1H TP/SL guard rails - AI still learns final TP/SL dynamically
MIN_1H_SL_PCT=0.0035
MIN_1H_TP_PCT=0.0050
MAX_1H_SL_PCT=0.0550

# Learning / symbol health
LEARNING_DAYS=21
SYMBOL_ERROR_DISABLE_AFTER=3
OKX_DISABLE_MINUTES=30
TOOBIT_REAL_DISABLE_HOURS=6

# Toobit endpoint overrides if your account/API variant needs them
# TOOBIT_PATH_BALANCE=/api/v1/futures/balance
# TOOBIT_PATH_POSITIONS=/api/v1/futures/positions
# TOOBIT_PATH_OPEN_ORDERS=/api/v1/futures/openOrders
# TOOBIT_PATH_MARGIN_MODE=/api/v1/futures/marginType
# TOOBIT_PATH_LEVERAGE=/api/v1/futures/leverage
# TOOBIT_PATH_POSITION_SETTINGS=/api/v1/futures/accountLeverage
# TOOBIT_PATH_ORDER=/api/v1/futures/order
# TOOBIT_PATH_MARK_PRICE=/api/v1/futures/markPrice
# TOOBIT_PATH_EXCHANGE_INFO=/api/v1/futures/exchangeInfo
# TOOBIT_PATH_HISTORY_POSITIONS=/api/v1/futures/historyPositions
# TOOBIT_PATH_TODAY_PNL=/api/v1/futures/todayPnl
# TOOBIT_PATH_CLOSE_ORDER=/api/v1/futures/order
# TOOBIT_PARAM_TP=takeProfit
# TOOBIT_PARAM_SL=stopLoss
# TOOBIT_DEFAULT_QUANTITY_STEP=0.0001
# TOOBIT_DEFAULT_PRICE_TICK=0.0001
# TOOBIT_DEFAULT_MIN_QTY=0
# TOOBIT_DEFAULT_MIN_NOTIONAL=0

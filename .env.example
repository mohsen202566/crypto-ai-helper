# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here
TELEGRAM_CHAT_ID=put_your_telegram_chat_id_here

# =========================
# Exchange / Toobit
# =========================
TOOBIT_API_KEY=put_your_toobit_api_key_here
TOOBIT_API_SECRET=put_your_toobit_api_secret_here
TOOBIT_BASE_URL=https://api.toobit.com

# =========================
# Trading Mode
# =========================
REAL_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true

# =========================
# Risk / Position
# =========================
DEFAULT_MARGIN_USDT=5
DEFAULT_LEVERAGE=10
MAX_OPEN_TRADES=3

# =========================
# Fee / Net PnL
# کارمزد باید در سود و ضرر خالص حساب شود
# اگر کارمزد تیکر صرافی 0.06% است یعنی 0.0006
# =========================
TAKER_FEE_RATE=0.0006
MAKER_FEE_RATE=0.0002
USE_TAKER_FEE_FOR_SIGNAL_PNL=true
SHOW_NET_PNL=true
MIN_NET_PROFIT_USDT=0.01

# =========================
# Learning
# شروع یادگیری جدید و واقعی
# =========================
FRESH_LEARNING=true
RESET_OLD_LEARNING=false

# =========================
# Fundamental / News Guard
# =========================
FUNDAMENTAL_EVENTS_FILE=fundamental_events.json
NEWS_GUARD_ENABLED=true
IMPORTANT_NEWS_BLOCK_MINUTES=15

# =========================
# Session Guard
# =========================
SESSION_GUARD_ENABLED=true
SESSION_OPEN_BLOCK_MINUTES=10

# =========================
# Logs / Database
# =========================
DATABASE_PATH=data/bot.db
LOG_LEVEL=INFO
